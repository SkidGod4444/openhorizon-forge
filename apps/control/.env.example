DATABASE_URL=postgres://postgres:postgres@localhost:5432/openhorizon
# Supabase pooler example:
# DATABASE_URL=postgresql://postgres.<project-ref>:[YOUR-PASSWORD]@aws-1-ap-south-1.pooler.supabase.com:6543/postgres
DATABASE_MAX_CONNECTIONS=10
PORT=8080
# Optional: when set, all endpoints except /healthz require:
# Authorization: Bearer <CONTROL_API_KEY>
CONTROL_API_KEY=

# Scheduler runtime:
# - slurm: submit via sbatch/squeue/sacct/scancel
# - k8s: submit via kubectl batch Job API
SCHEDULER_BACKEND=slurm

# Kubernetes mode settings (used only if SCHEDULER_BACKEND=k8s):
K8S_NAMESPACE=default
K8S_TRAIN_IMAGE=python:3.11
